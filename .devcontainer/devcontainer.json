{
  "__version": "2026-04-24T1004",
  "name": "Arc Claude Code Sandbox",
  "image": "ghcr.io/wpmedia/arc-claude-sandbox:latest",
  "__image": "arc-claude-sandbox-local",
  "runArgs": [
    "--cap-add=NET_ADMIN",
    "--cap-add=NET_RAW",
    "--name=arca-${localWorkspaceFolderBasename}"
  ],
  "customizations": {
    "vscode": {
      "extensions": [],
      "settings": {
        "editor.formatOnSave": true,
        "editor.codeActionsOnSave": {
          "source.fixAll.eslint": "explicit"
        },
        "terminal.integrated.defaultProfile.linux": "zsh",
        "terminal.integrated.profiles.linux": {
          "bash": {
            "path": "bash",
            "icon": "terminal-bash"
          },
          "zsh": {
            "path": "zsh"
          }
        }
      }
    }
  },
  "remoteUser": "node",
  "initializeCommand": {
    "make-logs-dir": "mkdir -p ${localWorkspaceFolder}/.devcontainer-logs; ",
    "add-logs-dir-to-gitignore": "grep -qxF '.devcontainer-logs' '${localWorkspaceFolder}/.gitignore' 2>/dev/null || printf '\\n.devcontainer-logs\\n' >> '${localWorkspaceFolder}/.gitignore'",
    "ensure-claude-dir": "mkdir -p \"${localEnv:HOME}/.claude\"",
    "detect-timezone": "readlink /etc/localtime | sed 's|.*/zoneinfo/||' > \"${localEnv:HOME}/.claude/.host-timezone\""
  },
  "mounts": [
    "source=claude-code-bashhistory-${devcontainerId},target=/commandhistory,type=volume",
    "source=${localWorkspaceFolder}/.devcontainer-logs,target=/var/log/devcontainer-logs,type=bind",
    "source=${localEnv:HOME}/.claude,target=/home/node/.claude,type=bind",
    "source=devcontainer-exclude-${devcontainerId},target=/workspace/${localWorkspaceFolderBasename}/.devcontainer-exclude,type=volume"
  ],
  "containerEnv": {
    "NODE_OPTIONS": "--max-old-space-size=4096",
    "CLAUDE_CONFIG_DIR": "/home/node/.claude",
    "WORKDIR": "/workspace/${localWorkspaceFolderBasename}"
  },
  "workspaceMount": "source=${localWorkspaceFolder},target=/workspace/${localWorkspaceFolderBasename},type=bind,consistency=delegated",
  "workspaceFolder": "/workspace/${localWorkspaceFolderBasename}",
  "postStartCommand": "sudo /usr/local/bin/init-devcontainer.sh \"$WORKDIR\"",
  "waitFor": "postStartCommand"
}