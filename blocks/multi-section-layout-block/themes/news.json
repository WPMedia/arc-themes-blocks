        "padding": "var(--global-spacing-5)",
        "border": "2px solid var(--color-brand-primary)",
        "background-color": "var(--color-background-primary)"
      }
    }
  },
  "multi-section-three-column": {
    "styles": {
      "default": {
        "margin-block": "var(--global-spacing-5)",
