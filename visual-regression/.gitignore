# Fusion CLI / visual-regression artifacts. The workflow generates these at run
# time and force-adds the ones Chromatic needs onto a throwaway branch.
node_modules/

# Secrets / runtime config — created on the CI runner, never committed.
.env
.npmrc

# Generated by generate-blocks-json.mjs (fetched + patched from Themes-V2-Starter).
blocks.json

# Fusion build scaffolding.
.fusion/
.dockerignore

# Captured screenshots and generated Storybook stories/build.
screenshots/
stories/*.stories.jsx
storybook-static/
